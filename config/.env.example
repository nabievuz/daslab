# DasLab — example environment (copy to .env; never commit the real .env)
# Secrets are never placed in prompts or tracked files (security baseline).

# --- ArcRift memory (local MCP) ---
ARCRIFT_PROJECT=daslab
GRAPH_BACKEND=local-openai            # graph/triple extraction via local Claude bridge (:8787)

# --- Ollama embeddings (local; Anthropic has no embeddings API) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Engine ---
DASLAB_ROOT=                          # leave empty → self-locating (git toplevel / file-relative)

# --- Dokploy (product deploys only; never-auto-approve to change) ---
DOKPLOY_API_URL=
DOKPLOY_API_KEY=                      # secret — provide locally, never commit
