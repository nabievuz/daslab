{
  "mcpServers": {
    "pencil": {
      "type": "stdio",
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "desktop"
      ]
    },
    "memory-bank": {
      "type": "stdio",
      "command": "env",
      "args": [
        "MEMORY_BANK_ROOT=${HOME}/memory-bank-data",
        "npx",
        "-y",
        "@allpepper/memory-bank-mcp@latest"
      ]
    }
  }
}
